cf() {
    [[ -f "$1" ]] || { echo "file not found: $1" >&2; return 1; }
    clip.exe < "$1"
}

cliptofile() {
    local file="$1"

    powershell.exe -NoProfile -Command \
        "[Console]::OutputEncoding = [System.Text.Encoding]::UTF8; Get-Clipboard -Raw" \
        | sed 's/\r$//' > "$file"
}

clipappend() {
    local file="$1"

    powershell.exe -NoProfile -Command \
        "[Console]::OutputEncoding = [System.Text.Encoding]::UTF8; Get-Clipboard -Raw" \
        | sed 's/\r$//' >> "$file"
}
