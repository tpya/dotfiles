cdd() {
    cd "$(wslpath "$(cmd.exe /c 'echo %USERPROFILE%' 2>/dev/null | tr -d '\r')")/Downloads"
}

cdesk() {
    cd "$(wslpath "$(cmd.exe /c 'echo %USERPROFILE%' 2>/dev/null | tr -d '\r')")/OneDrive/Desktop"
}

cliptofile() {
    local file="$1"

    if [[ -z "$file" ]]; then
        echo "Usage: cliptofile <file>" >&2
        return 1
    fi

    powershell.exe -NoProfile -Command \
        "[Console]::OutputEncoding = [System.Text.Encoding]::UTF8; Get-Clipboard -Raw" \
        | sed 's/\r$//' > "$file"

    # echo "Written to file: $file"
    echo "----- BEGIN FILE: $file -----"
    cat "$file"
    echo "----- END FILE: $file -----"
}

clipappend() {
    local file="$1"

    if [[ -z "$file" ]]; then
        echo "Usage: clipappend <file>" >&2
        return 1
    fi

    powershell.exe -NoProfile -Command \
        "[Console]::OutputEncoding = [System.Text.Encoding]::UTF8; Get-Clipboard -Raw" \
        | sed 's/\r$//' >> "$file"

    # echo "Appended to file: $file"
    echo "----- BEGIN FILE: $file -----"
    cat "$file"
    echo "----- END FILE: $file -----"
}
